#!/usr/bin/env bash
# Pre-commit hook: runs ruff lint, ruff format check, and fast tests
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or run: scripts/install-hooks.sh

set -e

echo "=== Pre-commit: ruff check ==="
ruff check .
echo "  Lint passed."

echo "=== Pre-commit: ruff format ==="
ruff format --check .
echo "  Format passed."

echo "=== Pre-commit: pytest (fast) ==="
python -m pytest tests/ -x -q -m "not slow and not integration" 2>&1 | tail -5
echo "  Tests passed."

echo "=== All pre-commit checks passed ==="
