# Colloquip Environment Configuration
# Copy to .env and fill in values

# === Required ===
DATABASE_URL=postgresql+asyncpg://colloquip:password@localhost:5432/colloquip
ANTHROPIC_API_KEY=sk-ant-...

# === Optional (have defaults) ===

# Environment: development | staging | production
ENVIRONMENT=development

# Embedding provider: mock | openai
EMBEDDING_PROVIDER=mock
OPENAI_API_KEY=sk-...

# Memory store: in_memory | pgvector
MEMORY_STORE=in_memory

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text  # text | json

# CORS (comma-separated origins for production)
CORS_ORIGINS=http://localhost:5173

# Cost limits
MAX_COST_PER_THREAD_USD=5.0
MONTHLY_BUDGET_USD=500.0

# Watchers
WATCHER_POLL_INTERVAL=300

# Redis (for watcher job queue)
REDIS_URL=redis://localhost:6379

# Docker Compose DB password
DB_PASSWORD=colloquip
