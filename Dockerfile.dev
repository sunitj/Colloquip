# Development Dockerfile with hot-reload and dev tools
FROM python:3.11-slim

RUN pip install --no-cache-dir uv

WORKDIR /app

# Install all dependencies including dev
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --extra api --extra db --extra db-pg --extra llm --extra embeddings --extra monitoring

# Copy source (will be overridden by volume mount in docker-compose.dev.yml)
COPY . .
RUN pip install --no-cache-dir --no-deps -e .

EXPOSE 8000
EXPOSE 5678

CMD ["uvicorn", "colloquip.api:create_app", "--factory", "--host", "0.0.0.0", "--port", "8000", "--reload"]
